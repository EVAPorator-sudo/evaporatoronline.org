{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "strict": true,
    "alwaysStrict": true,
    "moduleDetection": "force",
    "moduleResolution": "Node",
    "outDir": "dist",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "inlineSourceMap": true,
    "noImplicitAny": true
  },
  "include": [
    "src/**/*.ts"
  ]
}